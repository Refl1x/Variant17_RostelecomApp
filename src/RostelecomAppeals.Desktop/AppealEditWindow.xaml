<Window x:Class="RostelecomAppeals.Desktop.AppealEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обращение" Height="620" Width="620" WindowStartupLocation="CenterOwner" Background="{StaticResource RtBg}">
    <Border Margin="18" Background="White" CornerRadius="20" Padding="22">
        <ScrollViewer>
            <StackPanel>
                <TextBlock Text="Карточка обращения" FontSize="24" FontWeight="Bold" Foreground="{StaticResource RtPurple}"/>
                <TextBlock Text="ФИО/организация" Margin="4,14,4,0"/>
                <TextBox x:Name="ApplicantBox" MaxLength="100"/>
                <TextBlock Text="Телефон +7XXXXXXXXXX" Margin="4,8,4,0"/>
                <TextBox x:Name="PhoneBox" MaxLength="12"/>
                <TextBlock Text="Адрес" Margin="4,8,4,0"/>
                <TextBox x:Name="AddressBox" MaxLength="150"/>
                <TextBlock Text="Описание" Margin="4,8,4,0"/>
                <TextBox x:Name="DescriptionBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" MaxLength="200"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel><TextBlock Text="Тип"/><ComboBox x:Name="TypeBox" DisplayMemberPath="Name"/></StackPanel>
                    <StackPanel Grid.Column="1"><TextBlock Text="Статус"/><ComboBox x:Name="StatusBox" DisplayMemberPath="Name"/></StackPanel>
                    <StackPanel Grid.Column="2"><TextBlock Text="Приоритет"/><ComboBox x:Name="PriorityBox" DisplayMemberPath="Name"/></StackPanel>
                </Grid>
                <TextBlock Text="Назначенный специалист" Margin="4,8,4,0"/>
                <ComboBox x:Name="SpecialistBox" DisplayMemberPath="FullName"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                    <Button Content="Отмена" Click="Cancel_Click" Background="#6F6684"/>
                    <Button Content="Сохранить" Click="Save_Click" Background="#FF4F12"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
