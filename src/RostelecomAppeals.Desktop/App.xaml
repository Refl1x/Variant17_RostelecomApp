<Application x:Class="RostelecomAppeals.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="RtPurple" Color="#7700FF"/>
        <SolidColorBrush x:Key="RtDarkPurple" Color="#3D087B"/>
        <SolidColorBrush x:Key="RtOrange" Color="#FF4F12"/>
        <SolidColorBrush x:Key="RtBlue" Color="#00AEEF"/>
        <SolidColorBrush x:Key="RtBg" Color="#F5F3FB"/>
        <SolidColorBrush x:Key="RtCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="RtText" Color="#1D1B2F"/>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource RtPurple}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#DDD7EF"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#DDD7EF"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#DDD7EF"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="36"/>
        </Style>
    </Application.Resources>
</Application>
