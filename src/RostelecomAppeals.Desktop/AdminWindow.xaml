<Window x:Class="RostelecomAppeals.Desktop.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="640" Width="920" WindowStartupLocation="CenterOwner" Background="{StaticResource RtBg}">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="White" CornerRadius="18" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Администратор" FontSize="24" FontWeight="Bold" Foreground="{StaticResource RtPurple}"/>
                <TextBlock Text="Создание профилей, блокировка и назначение ролей. Для Auth используется Supabase signup." Foreground="#6F6684"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" Background="White" CornerRadius="18" Padding="8">
            <DataGrid x:Name="ProfilesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="220"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                    <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="190"/>
                    <DataGridCheckBoxColumn Header="Блок" Binding="{Binding IsBlocked}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="2" Background="White" CornerRadius="18" Padding="12" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Новый пользователь" FontWeight="Bold"/>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="150"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="FullNameBox" ToolTip="ФИО"/>
                    <TextBox x:Name="EmailBox" Grid.Column="1" ToolTip="Email"/>
                    <TextBox x:Name="PhoneBox" Grid.Column="2" ToolTip="Телефон" Text="+7"/>
                    <PasswordBox x:Name="PasswordBox" Grid.Column="3" ToolTip="Пароль"/>
                    <ComboBox x:Name="RoleBox" Grid.Column="4" DisplayMemberPath="Name"/>
                    <Button Grid.Column="5" Content="Создать" Click="Create_Click" Background="#FF4F12"/>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox x:Name="ChangeRoleBox" Width="180" DisplayMemberPath="Name"/>
                    <Button Content="Сменить роль" Click="ChangeRole_Click"/>
                    <Button Content="Блок/разблок" Click="Block_Click" Background="#E03131"/>
                    <Button Content="Обновить" Click="Refresh_Click" Background="#00AEEF"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
